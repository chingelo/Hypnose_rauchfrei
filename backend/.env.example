OPENAI_API_KEY=sk-...
HYPNOSE_MODEL_ID=ft:gpt-3.5-turbo-1106:personal::AzSLcCUs
# Neuer semantischer Router auf aktueller OpenAI-Modellbasis
# HYPNOSE_ROUTER_MODEL_ID=gpt-5-mini
# HYPNOSE_ROUTER_API_MODE=responses
# HYPNOSE_ROUTER_REASONING_EFFORT=low
# HYPNOSE_ROUTER_VERBOSITY=low
# Optional:
# OPENAI_BASE_URL=https://api.openai.com/v1
# INTEGRATION_SIGNING_SECRET=change-me
# INTEGRATION_WEBHOOK_SECRET=change-me
# TEST_APP_RUNTIME_STATE_DIR=C:\Pfad\zu\lokalem_runtime_state
# RAUCHFREI_PACKAGE_ROOT=C:\Pfad\zum\rauchfrei_paket

# AIVORA-kompatible Stimme (Google TTS, de-DE, MALE)
# Wenn GOOGLE_APPLICATION_CREDENTIALS global gesetzt ist, ist hier nichts noetig.
# GOOGLE_TTS_KEY=C:\Pfad\zu\service-account.json
# Optional fuer den Sandbox-Runner mit --speak:
# SESSION_SANDBOX_TTS_PROVIDER=google
# SESSION_SANDBOX_TTS_VOICE_NAME=de-DE-Chirp3-HD-Iapetus
# Alternativ:
# SESSION_SANDBOX_TTS_PROVIDER=elevenlabs
# SESSION_SANDBOX_ELEVENLABS_VOICE_ID=...
# SESSION_SANDBOX_TTS_LEAD_IN_MS=180
# SESSION_SANDBOX_TTS_POST_BLOCK_PAUSE_MS=320
